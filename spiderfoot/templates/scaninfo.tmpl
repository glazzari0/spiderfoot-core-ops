## -*- coding: utf-8 -*-
<%include file="HEADER.tmpl"/>
<%
  if status == "FINISHED":
    statusy = "alert-success"
  elif status.startswith("ABORT"):
    statusy = "alert-warning"
  elif status == "CREATED" or status == "RUNNING" or status == "STARTED" or status == "STARTING" or status == "INITIALIZING":
    statusy = "alert-info"
  elif status == "ERROR-FAILED":
    statusy = "alert-danger"
  else:
    statusy = "alert-info"
  end
%>
<div class="sf-page-shell">
  <div class="sf-page-header">
    <div>
      <h2 class="sf-page-title">${name}&nbsp;<span id='scanstatusbadge' class='badge ${statusy}'>${status}</span>&nbsp;<img id="loader" src="${docroot}/static/img/loader.gif"></h2>
      <div class="sf-page-subtitle">Acompanhe o progresso, navegue pelos achados e revise a configuração desta varredura com menos ruído visual.</div>
    </div>
  </div>
  <div class="btn-toolbar sf-toolbar" role="toolbar" style='padding-bottom: 10px'>
   <div class="btn-group">
      <a id='btn-status' class="btn btn-default" onClick='scanSummaryView("${id}")'><i class='glyphicon glyphicon-eye-open'></i>&nbsp;Resumo</a>
      <a id='btn-correlations' class="btn btn-default" onClick='browseCorrelations("${id}")'><i class='glyphicon glyphicon-exclamation-sign'></i>&nbsp;Correlações</a>
      <a id='btn-browse' class="btn btn-default" onClick='browseEventList("${id}")'><i class='glyphicon glyphicon-th-list'></i>&nbsp;Navegar</a>
      <a id='btn-graph' class="btn btn-default" onClick='graphEvents("${id}")'><i class='glyphicon glyphicon-asterisk'></i>&nbsp;Grafo</a>
      <a id='btn-info' class="btn btn-default" onClick='viewScanConfig("${id}")'><i class='glyphicon glyphicon-cog'></i>&nbsp;Configurações da Varredura</a>
      <a id='btn-log' class="btn btn-default" onClick='viewScanLog("${id}")'><i class='glyphicon glyphicon-book'></i>&nbsp;Log</a>
    </div>
    <div class='btn-group pull-right'>
        <div id='btn-search' class='input-group pull-right'>
          <input class='form-control' id='searchvalue' type='text' placeholder='Pesquisar...' data-toggle='popover' data-html='true' data-animation='true' data-title='Uso' data-content="Informe uma expressão regular entre '/', por exemplo <i>/searchregex/</i>, ou uma busca com curinga, por exemplo <i>*texto*</i>, ou um valor exato, por exemplo <i>texto</i>.<br /><br /><b>Observação</b>: a busca respeita o escopo atual exibido.">
            <div class='input-group-btn' style='width: 0px'> <!-- Chrome fix -->
              <button class='btn btn-primary' id='searchbutton' type='button' onClick="$('#btn-search').popover('toggle');searchDirector('${id}')">
                <i class='glyphicon glyphicon-search glyphicon glyphicon-white'></i>
              </button>
            </div>
        </div>
    </div>
        <div class="btn-group pull-right" role="group">
            <button id='btn-refresh' rel="tooltip" title="Atualizar" class="btn btn-success btn-default" onClick='refresh()'><i class='glyphicon glyphicon-refresh glyphicon glyphicon-white'></i></button>
            <button id='btn-download-logs' rel="tooltip" data-title="Baixar Logs da Varredura" class="btn btn-default download-button" onClick='downloadLogs("${id}")'><i class='glyphicon glyphicon-download-alt glyphicon glyphicon-white'></i></button>
            <a id='btn-export' rel="tooltip" data-title="Exportar Dados" class="btn btn-default dropdown-toggle download-button" data-toggle="dropdown"><i class='glyphicon glyphicon-download-alt glyphicon glyphicon-white'></i></a>
            <ul class="dropdown-menu">
              <li><a class='link' onClick='exportEventData("${id}", currentType, "csv")'>CSV</a></li>
              <li><a class='link' onClick='exportEventData("${id}", currentType, "excel")'>Excel</a></li>
            </ul>
        </div> 
        <div id='customtabview' role="group" class="btn-group pull-right">
         <a id='btn-fullview' rel="tooltip" data-title="Visualização Completa" class="btn btn-default active" onClick='browseUpdate("full")'><i class='glyphicon glyphicon-th glyphicon glyphicon-white'></i></a>
         <a id='btn-uniqueview' rel="tooltip" data-title="Visualização Única" class="btn btn-default" onClick='browseUpdate("unique")'><i class='glyphicon glyphicon-align-justify glyphicon glyphicon-white'></i></a>
         <a id='btn-vizview' rel="tooltip" data-title="Visualizar" class="btn btn-default dropdown-toggle" data-toggle="dropdown"><i class='glyphicon glyphicon-picture glyphicon glyphicon-white'></i></a>
         <ul class="dropdown-menu">
            <li><a class='link' onClick='browseUpdate("viz-bubble-data")'>Bolhas (Elemento de Dados)</a></li>
            <li><a class='link' onClick='browseUpdate("viz-bubble-source")'>Bolhas (Elemento de Origem)</a></li>
            <li><a class='link' onClick='browseUpdate("viz-dendro")'>Caminho de Descoberta</a></li>
         </ul>
        </div>
        <div id='customvizview' class="btn-group pull-right">
         <a id='btn-random' rel="tooltip" data-title="Layout Aleatório" class="btn btn-default active" onClick='vizUpdate("random")'><b>R</b></a>
         <a id='btn-forceatlas' rel="tooltip" data-title="Layout por Força" class="btn btn-default" onClick='vizUpdate("force")'><b>F</b></a>
         <a id='btn-saveimage' rel="tooltip" data-title="Salvar Imagem" class="btn btn-default dropdown-toggle" onClick='vizUpdate("download")'><i class='glyphicon glyphicon-picture glyphicon glyphicon-white'></i></a>
        </div>
        <div id='customgraphlabels' class="btn-group pull-right" style="display: none;">
         <a id='btn-labels-relevant' rel="tooltip" data-title="Mostrar rótulos relevantes" class="btn btn-default active" onClick='graphLabelModeUpdate("relevant")'>Rótulos: Auto</a>
         <a id='btn-labels-all' rel="tooltip" data-title="Mostrar todos os rótulos" class="btn btn-default" onClick='graphLabelModeUpdate("all")'>Todos</a>
         <a id='btn-labels-off' rel="tooltip" data-title="Ocultar rótulos" class="btn btn-default" onClick='graphLabelModeUpdate("off")'>Ocultar</a>
        </div>
        <div id='modifyactions' role="group" class="btn-group pull-right">
            <a id='btn-setfp' rel="tooltip" data-title="Definir/Remover marcação de Falso Positivo" class="btn-warning btn btn-default dropdown-toggle" data-toggle="dropdown"><i class='glyphicon glyphicon-ban-circle glyphicon glyphicon-white'></i></a>
            <ul class="dropdown-menu">
                <li><a href='#' class='link' onClick='setFp(1)'>Marcar como Falso Positivo</a></li>
                <li><a href='#' class='link' onClick='setFp(0)'>Remover marcação de Falso Positivo</a></li>
            </ul>
        </div>
  </div>
    <script src="${docroot}/static/node_modules/sigma/build/sigma.min.js"></script>
    <script src="${docroot}/static/node_modules/sigma/build/plugins/sigma.parsers.json.min.js"></script>
    <script src="${docroot}/static/node_modules/sigma/build/plugins/sigma.plugins.dragNodes.min.js"></script>
    <script src="${docroot}/static/node_modules/sigma/build/plugins/sigma.layout.forceAtlas2.min.js"></script>
    <script src="${docroot}/static/node_modules/sigma/build/plugins/sigma.renderers.snapshot.min.js"></script>
    <script type='text/javascript'>
        var currentType = "ALL";
        var currentTypeName = "All";
        var currentSection = "btn-browse";
        var lastSearchType = "ALL";
        var lastSearchQuery = "";
        var dataloaders = [];
        var sharedSigma = "";
        var graphLabelMode = "relevant";
        var currentFindingHash = "";
        var currentFindingRowSelector = "";
        var currentAiSuggestion = null;
        var currentEvidenceId = "";
        var findingOptionLabels = {
            triage_status: {"novo":"Novo","em_triagem":"Em triagem","relevante":"Relevante","descartado":"Descartado","falso_positivo":"Falso positivo","confirmado":"Confirmado"},
            relevance: {"pendente":"Pendente","baixa":"Baixa","media":"Média","alta":"Alta","critica":"Crítica"},
            exploitability: {"nao_avaliado":"Não avaliado","nao_aplicavel":"Não aplicável","nao_exploravel":"Não explorável","potencial":"Potencial","confirmada":"Confirmada"},
            analyst_verdict: {"em_analise":"Em análise","monitorar":"Monitorar","sem_risco_pratico":"Sem risco prático","exposto_confirmado":"Exposto e confirmado","exploravel":"Explorável","critico":"Crítico"}
        };
        var loadersrunning = false;
        var refresh = function() { browseEventList("${id}"); }
        $('#searchvalue').popover({ 'trigger': 'focus', 'placement': 'bottom'});
        $('#searchvalue').keyup(function(event) {
            if (event.keyCode == 13) {
                $('#searchbutton').click();
            }
        });

        function switchSelectAll() {
            if (!$("#checkall")[0].checked) {
                $("input[id*=cb_]").prop('checked', false);
            } else {
                $("input[id*=cb_]").prop('checked', true);
            }
        }

        function getSelected() {
            ids = [];
            $("input[id*=cb_]").each(function(i, obj) {
                if (obj.checked) {
                    ids[ids.length] = obj.id.replace("cb_", "");
                }
            });

            return ids;
        }

        function setFp(flag) {
            sel = getSelected();
            if (sel.length == 0) {
                alertify.error("Você precisa selecionar pelo menos um registro.");
                return false;
            }
            data = JSON.stringify(sel);
            $("#loader").show();
            sf.fetchData('${docroot}/resultsetfp', {'id': '${id}', 'fp': flag, 'resultids': data }, function(ret) {
                $("#loader").hide();
                if (ret[0] == "SUCCESS") {
                    refresh();
                    return;
                }
                if (ret[0] == "WARNING") {
                    alertify.error(ret[1]);
                    return;
                }
                if (ret[0] == "ERROR") {
                    alertify.error("Ocorreu um erro ao definir falsos positivos: " + ret[1] + "<br/>Se você acredita que isso seja um erro, saia e entre novamente. Se o problema persistir, reporte como bug.");
                }
            });
        }

        function escapeHtmlText(value) {
            return $("<div>").text(value == null ? "" : String(value)).html();
        }

        function renderFindingSelectOptions(groupName, selectedValue) {
            var options = "";
            var labels = findingOptionLabels[groupName] || {};
            Object.keys(labels).forEach(function(key) {
                options += "<option value='" + key + "'" + (selectedValue == key ? " selected" : "") + ">" + escapeHtmlText(labels[key]) + "</option>";
            });
            return options;
        }

        function findingBadgeClass(value) {
            if (value == "ok") {
                return "alert-success";
            }
            if (value == "warning") {
                return "alert-warning";
            }
            if (value == "error") {
                return "alert-danger";
            }
            if (value == "confirmado" || value == "critica" || value == "exploravel" || value == "critico" || value == "confirmada") {
                return "alert-danger";
            }
            if (value == "relevante" || value == "alta" || value == "potencial" || value == "exposto_confirmado" || value == "em_triagem") {
                return "alert-warning";
            }
            if (value == "descartado" || value == "falso_positivo" || value == "nao_exploravel" || value == "nao_aplicavel" || value == "sem_risco_pratico") {
                return "alert-success";
            }
            return "alert-info";
        }

        function refreshOperationalSummary(instanceId) {
            sf.fetchData('${docroot}/scanopssummary', {'id': instanceId}, function(data) {
                if (!data || !data.summary) {
                    return;
                }
                var triageHtml = "";
                Object.keys(findingOptionLabels.triage_status).forEach(function(key) {
                    triageHtml += "<div><span class='badge " + findingBadgeClass(key) + "'>" + escapeHtmlText(findingOptionLabels.triage_status[key]) + "</span> " + (data.summary.triage_status[key] || 0) + "</div>";
                });
                var exploitHtml = "";
                Object.keys(findingOptionLabels.exploitability).forEach(function(key) {
                    exploitHtml += "<div><span class='badge " + findingBadgeClass(key) + "'>" + escapeHtmlText(findingOptionLabels.exploitability[key]) + "</span> " + (data.summary.exploitability[key] || 0) + "</div>";
                });
                $("#ops-triage-breakdown").html(triageHtml);
                $("#ops-exploit-breakdown").html(exploitHtml);
                $("#ops-evidence-count").text(data.summary.evidence_count || 0);
                $("#ops-validation-count").text(data.summary.validation_count || 0);
                $("#case-verdict").html(renderFindingSelectOptions("analyst_verdict", data.verdict.verdict));
                $("#case-verdict-summary").val(data.verdict.summary || "");
                $("#case-verdict-updated").text(data.verdict.updated ? "Atualizado" : "Ainda sem veredito final salvo.");
            });
        }

        function saveCaseVerdict(instanceId) {
            sf.fetchData('${docroot}/scanverdictupdate', {
                'id': instanceId,
                'verdict': $("#case-verdict").val(),
                'summary': $("#case-verdict-summary").val()
            }, function(ret) {
                if (ret[0] == "SUCCESS") {
                    alertify.success(ret[1]);
                    refreshOperationalSummary(instanceId);
                } else {
                    alertify.error(ret[1]);
                }
            });
        }

        function openFindingWorkbench(instanceId, resultHash, triggerEl) {
            var nextRowSelector = "#finding-row-" + resultHash;
            if (triggerEl) {
                currentFindingRowSelector = nextRowSelector;
            }

            if (currentFindingHash === resultHash && triggerEl && $("#finding-inline-row").is(":visible")) {
                $("#finding-inline-row").hide();
                currentFindingHash = "";
                currentAiSuggestion = null;
                return;
            }

            if (currentFindingHash && currentFindingHash != resultHash) {
                currentAiSuggestion = null;
            }
            currentFindingHash = resultHash;
            if ($(currentFindingRowSelector).length > 0) {
                $("#finding-inline-row").insertAfter($(currentFindingRowSelector));
            }
            $("#finding-inline-row").show();
            $("#finding-workbench-loading").show();
            $("#finding-workbench-content").hide();
            sf.fetchData('${docroot}/findingdetail', {'id': instanceId, 'resulthash': resultHash}, function(data) {
                $("#finding-workbench-loading").hide();
                $("#finding-workbench-content").show();
                if (!data || data.error) {
                    $("#finding-meta").html("<div class='alert alert-danger'>Não foi possível carregar o achado selecionado.</div>");
                    return;
                }
                var finding = data.finding || {};
                var state = data.state || {};
                $("#finding-selected-hash").text(finding.hash || resultHash);
                $("#finding-meta").html(
                    "<div><b>Tipo:</b> " + escapeHtmlText(finding.event_label || finding.event_type || "-") + "</div>" +
                    "<div><b>Dado:</b> " + escapeHtmlText(finding.data || "-") + "</div>" +
                    "<div><b>Origem:</b> " + escapeHtmlText(finding.source_data || "-") + "</div>" +
                    "<div><b>Módulo:</b> " + escapeHtmlText(finding.module || "-") + "</div>" +
                    "<div><b>Coletado em:</b> " + escapeHtmlText(finding.generated || "-") + "</div>" +
                    "<div style='margin-top:8px;'><b>Validador:</b> " + escapeHtmlText((data.validator_support || {}).validator || "generic_observation") + "</div>" +
                    "<div class='text-muted font-size-90-percent'>" + escapeHtmlText((data.validator_support || {}).description || "Sem descrição.") + "</div>"
                );
                $("#finding-triage-status").html(renderFindingSelectOptions("triage_status", state.triage_status));
                $("#finding-relevance").html(renderFindingSelectOptions("relevance", state.relevance));
                $("#finding-exploitability").html(renderFindingSelectOptions("exploitability", state.exploitability));
                $("#finding-analyst-verdict").html(renderFindingSelectOptions("analyst_verdict", state.analyst_verdict));
                $("#finding-notes").val(state.notes || "");
                currentEvidenceId = "";
                $("#finding-evidence-save-label").text("Adicionar evidência");
                $("#finding-evidence-type").val("nota");
                $("#finding-evidence-title").val("");
                $("#finding-evidence-content").val("");
                $("#finding-ai-config-status").html(
                    data.ai && data.ai.configured
                        ? "<span class='text-success'>Ollama pronto: " + escapeHtmlText(data.ai.model || "modelo não identificado") + "</span>"
                        : "<span class='text-warning'>Configure a aba IA / Ollama para usar a análise assistida.</span>"
                );
                if (currentAiSuggestion) {
                    renderFindingAiAnalysis(currentAiSuggestion);
                } else {
                    $("#finding-ai-analysis").html("<div class='text-muted'>Execute a análise assistida para receber uma sugestão de triagem, relevância, explorabilidade, veredito e próximos passos.</div>");
                }

                var evidenceHtml = data.evidence.length
                    ? data.evidence.map(function(item) {
                        return "<div class='sf-inline-card'><div><b>" + escapeHtmlText(item.title) + "</b> <span class='text-muted'>(" + escapeHtmlText(item.evidence_type) + ")</span> <button class='btn btn-xs btn-default pull-right' onClick='loadEvidenceForEdit(" + JSON.stringify(item.id) + ", " + JSON.stringify(item.evidence_type) + ", " + JSON.stringify(item.title) + ", " + JSON.stringify(item.content) + ")'>Editar</button></div><div class='font-size-90-percent'>" + escapeHtmlText(item.content) + "</div><div class='text-muted font-size-90-percent'>" + item.created + "</div></div>";
                      }).join("")
                    : "<div class='text-muted'>Nenhuma evidência registrada para este achado.</div>";
                $("#finding-evidence-list").html(evidenceHtml);

                var validationHtml = data.validations.length
                    ? data.validations.map(function(item) {
                        return "<div class='sf-inline-card'><div><span class='badge " + findingBadgeClass(item.status) + "'>" + escapeHtmlText(item.status) + "</span> <b>" + escapeHtmlText(item.validator) + "</b></div><div>" + escapeHtmlText(item.summary) + "</div><pre class='table-border-bg-inherit' style='white-space: pre-wrap; margin-top: 6px;'>" + escapeHtmlText(item.details) + "</pre><div class='text-muted font-size-90-percent'>" + item.created + "</div></div>";
                      }).join("")
                    : "<div class='text-muted'>Nenhuma validação executada ainda.</div>";
                $("#finding-validation-list").html(validationHtml);
            });
        }

        function saveFindingState(instanceId) {
            if (!currentFindingHash) {
                alertify.error("Selecione um achado antes de salvar.");
                return;
            }
            sf.fetchData('${docroot}/findingupdate', {
                'id': instanceId,
                'resulthash': currentFindingHash,
                'triage_status': $("#finding-triage-status").val(),
                'relevance': $("#finding-relevance").val(),
                'exploitability': $("#finding-exploitability").val(),
                'analyst_verdict': $("#finding-analyst-verdict").val(),
                'notes': $("#finding-notes").val()
            }, function(ret) {
                if (ret[0] == "SUCCESS") {
                    alertify.success(ret[1]);
                    openFindingWorkbench(instanceId, currentFindingHash);
                    refreshOperationalSummary(instanceId);
                } else {
                    alertify.error(ret[1]);
                }
            });
        }

        function addFindingEvidence(instanceId) {
            if (!currentFindingHash) {
                alertify.error("Selecione um achado antes de anexar evidência.");
                return;
            }
            var targetUrl = currentEvidenceId ? '${docroot}/findingevidenceupdate' : '${docroot}/findingevidenceadd';
            var payload = {
                'id': instanceId,
                'resulthash': currentFindingHash,
                'evidence_type': $("#finding-evidence-type").val(),
                'title': $("#finding-evidence-title").val(),
                'content': $("#finding-evidence-content").val()
            };
            if (currentEvidenceId) {
                payload['evidence_id'] = currentEvidenceId;
            }
            sf.fetchData(targetUrl, payload, function(ret) {
                if (ret[0] == "SUCCESS") {
                    alertify.success(ret[1]);
                    currentEvidenceId = "";
                    $("#finding-evidence-save-label").text("Adicionar evidência");
                    $("#finding-evidence-type").val("nota");
                    $("#finding-evidence-title").val("");
                    $("#finding-evidence-content").val("");
                    openFindingWorkbench(instanceId, currentFindingHash);
                    refreshOperationalSummary(instanceId);
                } else {
                    alertify.error(ret[1]);
                }
            });
        }

        function loadEvidenceForEdit(evidenceId, evidenceType, title, content) {
            currentEvidenceId = evidenceId;
            $("#finding-evidence-save-label").text("Salvar evidência");
            $("#finding-evidence-type").val(evidenceType);
            $("#finding-evidence-title").val(title);
            $("#finding-evidence-content").val(content);
        }

        function validateFinding(instanceId) {
            if (!currentFindingHash) {
                alertify.error("Selecione um achado antes de validar.");
                return;
            }
            sf.fetchData('${docroot}/findingvalidate', {'id': instanceId, 'resulthash': currentFindingHash}, function(ret) {
                if (ret[0] == "SUCCESS") {
                    alertify.success(ret[1]);
                    openFindingWorkbench(instanceId, currentFindingHash);
                    refreshOperationalSummary(instanceId);
                } else {
                    alertify.error(ret[1]);
                }
            });
        }

        function renderFindingAiAnalysis(analysis) {
            if (!analysis) {
                $("#finding-ai-analysis").html("<div class='text-muted'>Nenhuma análise assistida disponível.</div>");
                return;
            }

            var reasoning = (analysis.reasoning || []).length
                ? "<ul><li>" + analysis.reasoning.map(escapeHtmlText).join("</li><li>") + "</li></ul>"
                : "<div class='text-muted'>Sem racional detalhado.</div>";
            var gaps = (analysis.evidence_gaps || []).length
                ? "<ul><li>" + analysis.evidence_gaps.map(escapeHtmlText).join("</li><li>") + "</li></ul>"
                : "<div class='text-muted'>Nenhuma lacuna específica apontada.</div>";
            var nextSteps = (analysis.next_steps || []).length
                ? "<ul><li>" + analysis.next_steps.map(escapeHtmlText).join("</li><li>") + "</li></ul>"
                : "<div class='text-muted'>Sem próximos passos sugeridos.</div>";

            var html = "";
            html += "<div class='sf-inline-card'>";
            html += "<div><b>Resumo</b> <span class='text-muted'>(solicitado: " + escapeHtmlText(analysis.requested_model || analysis.model || "ollama") + ", retornado: " + escapeHtmlText(analysis.resolved_model || analysis.model || "ollama") + ", confiança " + escapeHtmlText(analysis.confidence || 0) + "%)</span></div>";
            html += "<div style='margin-top: 6px;'>" + escapeHtmlText(analysis.summary || "") + "</div>";
            html += "<div class='row' style='margin-top: 10px;'>";
            html += "<div class='col-sm-6'><b>Triagem sugerida:</b> " + escapeHtmlText((findingOptionLabels.triage_status || {})[analysis.triage_status_suggestion] || analysis.triage_status_suggestion || "-") + "</div>";
            html += "<div class='col-sm-6'><b>Relevância sugerida:</b> " + escapeHtmlText((findingOptionLabels.relevance || {})[analysis.relevance_suggestion] || analysis.relevance_suggestion || "-") + "</div>";
            html += "</div>";
            html += "<div class='row' style='margin-top: 6px;'>";
            html += "<div class='col-sm-6'><b>Explorabilidade sugerida:</b> " + escapeHtmlText((findingOptionLabels.exploitability || {})[analysis.exploitability_suggestion] || analysis.exploitability_suggestion || "-") + "</div>";
            html += "<div class='col-sm-6'><b>Veredito sugerido:</b> " + escapeHtmlText((findingOptionLabels.analyst_verdict || {})[analysis.analyst_verdict_suggestion] || analysis.analyst_verdict_suggestion || "-") + "</div>";
            html += "</div>";
            html += "<div style='margin-top: 10px;'><b>Racional</b>" + reasoning + "</div>";
            html += "<div style='margin-top: 10px;'><b>Lacunas de evidência</b>" + gaps + "</div>";
            html += "<div style='margin-top: 10px;'><b>Próximos passos</b>" + nextSteps + "</div>";
            html += "<div style='margin-top: 10px;'><b>Evidência sugerida</b><div><span class='text-muted'>Tipo:</span> " + escapeHtmlText(analysis.suggested_evidence_type || "nota") + "</div><div><span class='text-muted'>Título:</span> " + escapeHtmlText(analysis.suggested_evidence_title || "") + "</div><pre class='table-border-bg-inherit' style='white-space: pre-wrap; margin-top: 6px;'>" + escapeHtmlText(analysis.suggested_evidence_content || "") + "</pre></div>";
            html += "<div style='margin-top: 10px;'><b>Rascunho de nota</b><pre class='table-border-bg-inherit' style='white-space: pre-wrap; margin-top: 6px;'>" + escapeHtmlText(analysis.operator_note_draft || "") + "</pre></div>";
            html += "</div>";
            $("#finding-ai-analysis").html(html);
        }

        function requestFindingAiAssist(instanceId) {
            if (!currentFindingHash) {
                alertify.error("Selecione um achado antes de usar a análise assistida.");
                return;
            }
            sf.log("Solicitando análise assistida por IA para o achado " + currentFindingHash + " da varredura " + instanceId);
            $("#finding-ai-analysis").html("<div class='text-muted'>Consultando o Ollama local e montando a análise assistida...</div>");
            $.ajax({
                type: "POST",
                url: '${docroot}/findingaiassist',
                data: {'id': instanceId, 'resulthash': currentFindingHash, 'save_evidence': 1},
                cache: false,
                dataType: "json"
            }).done(function(ret) {
                if (!ret || ret.error || ret.status != "SUCCESS") {
                    var message = (ret && ret.error && ret.error.message) || "Falha ao executar a análise assistida.";
                    $("#finding-ai-analysis").html("<div class='alert alert-danger'>" + escapeHtmlText(message) + "</div>");
                    alertify.error(message);
                    sf.log("Falha na análise assistida por IA: " + message);
                    return;
                }
                currentAiSuggestion = ret.analysis || null;
                renderFindingAiAnalysis(currentAiSuggestion);
                if (ret.saved_as_evidence) {
                    alertify.success("Análise assistida concluída e registrada como evidência.");
                } else {
                    alertify.success("Análise assistida concluída.");
                }
                sf.log("Análise assistida por IA concluída com sucesso para " + currentFindingHash);
                openFindingWorkbench(instanceId, currentFindingHash);
                refreshOperationalSummary(instanceId);
            }).fail(function(hr, status) {
                var message = "Falha ao executar a análise assistida.";
                if (hr.responseJSON && hr.responseJSON.error && hr.responseJSON.error.message) {
                    message = hr.responseJSON.error.message;
                } else if (hr.responseText) {
                    message = hr.responseText;
                } else if (status) {
                    message = status;
                }
                $("#finding-ai-analysis").html("<div class='alert alert-danger'>" + escapeHtmlText(message) + "</div>");
                alertify.error(message);
                sf.log("Erro HTTP na análise assistida por IA: " + message);
            });
        }

        function applyAiSuggestions() {
            if (!currentAiSuggestion) {
                alertify.error("Execute primeiro a análise assistida por IA.");
                return;
            }
            $("#finding-triage-status").val(currentAiSuggestion.triage_status_suggestion || "em_triagem");
            $("#finding-relevance").val(currentAiSuggestion.relevance_suggestion || "pendente");
            $("#finding-exploitability").val(currentAiSuggestion.exploitability_suggestion || "nao_avaliado");
            $("#finding-analyst-verdict").val(currentAiSuggestion.analyst_verdict_suggestion || "em_analise");

            if ($("#finding-notes").val().trim() === "" && currentAiSuggestion.operator_note_draft) {
                $("#finding-notes").val(currentAiSuggestion.operator_note_draft);
            }
            if ($("#finding-evidence-type").val() === "nota" && currentAiSuggestion.suggested_evidence_type) {
                $("#finding-evidence-type").val(currentAiSuggestion.suggested_evidence_type);
            }
            if ($("#finding-evidence-title").val().trim() === "" && currentAiSuggestion.suggested_evidence_title) {
                $("#finding-evidence-title").val(currentAiSuggestion.suggested_evidence_title);
            }
            if ($("#finding-evidence-content").val().trim() === "" && currentAiSuggestion.suggested_evidence_content) {
                $("#finding-evidence-content").val(currentAiSuggestion.suggested_evidence_content);
            }
            alertify.success("Sugestões da IA aplicadas aos campos. Revise e salve quando quiser.");
        }

