            grid += "<div><span style='color:#51cf66'>●</span> Domínios / hostnames</div>"
            grid += "<div><span style='color:#4dabf7'>●</span> IPs / redes</div>"
            grid += "<div><span style='color:#f59f00'>●</span> E-mails</div>"
            grid += "<div><span style='color:#ff922b'>●</span> Pessoas</div>"
            grid += "<div><span style='color:#fcc419'>●</span> Usernames</div>"
            grid += "<div><span style='color:#845ef7'>●</span> Perfis / contas externas</div>"
            grid += "<div><span style='color:#20c997'>●</span> Repositórios / apps / localização</div>"
            grid += "<div><span style='color:#ced4da'>●</span> Outros tipos mapeados genericamente</div>"
            grid += "</div>"
            grid += "<div class='font-size-90-percent' style='margin-bottom: 12px;'>Nodos maiores tendem a ter mais relações e mais módulos associados.</div>"
            grid += "<div id='graph-node-info' class='font-size-90-percent' style='word-break: break-word; overflow-wrap: anywhere; line-height: 1.5;'>Passe o mouse ou clique em um nodo para ver detalhes.</div>"
            grid += "</div></div></div>"
            grid += "</div></div>"

            $("#scansummary-content").remove();
            $("#scanlogs-content").remove();
            $("#loader").show();
            $("#btn-export").show();
            $("#btn-download-logs").hide();
            $("#btn-refresh").show();
            $("#btn-search").hide();
            $("#btn-graph").show();
            $("#scanreminder").hide();
            refresh = function() { graphEvents(instanceId); }
            navTo("btn-graph");
            $("#customvizview").show();
            $("#customgraphlabels").show();
            $("#mainbody").append(grid);
            $("#btn-forceatlas").removeClass("active");
            $("#btn-random").addClass("active");
            $("#btn-labels-relevant").addClass("active");
            $("#btn-labels-all").removeClass("active");
            $("#btn-labels-off").removeClass("active");

            sigma.renderers.def = sigma.renderers.canvas
            sigma.parsers.json("${docroot}/scanviz?id=" + instanceId + "&gexf=0", {
                container: 'graph-container'
            }, function(s) { 
                if (s.renderers[0].nodesOnScreen.length == 0) {
                    $("#graph-container").append("<div class='alert alert-danger'>Insufficient data to produce a graph.</div>");
                    $("#loader").hide();
                    return;
                }
                sharedSigma = s;
                function cleanGraphText(text) {
                    return String(text || "")
                        .replace(/<\/?sfurl>/gi, " ")
                        .replace(/&lt;\/?sfurl&gt;/gi, " ")
                        .replace(/\s+/g, " ")
                        .trim();
                }
                function inferGraphNodeColor(node) {
                    var eventType = String(node.sfEventType || "").toUpperCase();
                    var eventLabel = String(node.sfEventLabel || "").toUpperCase().replace(/[^A-Z0-9]+/g, "_");
                    var labelText = cleanGraphText(node.sfFullLabel || node.label || "");
                    var lowerLabel = labelText.toLowerCase();
                    var color = "";

                    var eventPalette = {
                        "HUMAN_NAME": "#ff6b6b",
                        "USERNAME": "#fcc419",
                        "EMAILADDR": "#f59f00",
                        "AFFILIATE_EMAILADDR": "#ffb347",
                        "IP_ADDRESS": "#4dabf7",
                        "IPV6_ADDRESS": "#4dabf7",
                        "NETBLOCK_OWNER": "#74c0fc",
                        "NETBLOCKV6_OWNER": "#74c0fc",
                        "DOMAIN_NAME": "#51cf66",
                        "INTERNET_NAME": "#51cf66",
                        "INTERNET_NAME_UNRESOLVED": "#74c69d",
                        "AFFILIATE_INTERNET_NAME": "#8ce99a",
                        "AFFILIATE_DOMAIN_NAME": "#8ce99a",
                        "SOCIAL_MEDIA": "#845ef7",
                        "ACCOUNT_EXTERNAL_OWNED": "#845ef7",
                        "SIMILAR_ACCOUNT_EXTERNAL": "#b197fc",
                        "PUBLIC_CODE_REPO": "#20c997",
                        "APPSTORE_ENTRY": "#20c997",
                        "CLOUD_STORAGE_BUCKET": "#20c997",
                        "COMPANY_NAME": "#f06595",
                        "AFFILIATE_COMPANY_NAME": "#faa2c1",
                        "PHONE_NUMBER": "#9775fa",
                        "BITCOIN_ADDRESS": "#fab005",
                        "COUNTRY_NAME": "#20c997",
                        "PHYSICAL_ADDRESS": "#20c997",
                        "PHYSICAL_COORDINATES": "#20c997"
                    };

                    if (eventPalette[eventType]) {
                        return eventPalette[eventType];
                    }

                    if (eventPalette[eventLabel]) {
                        return eventPalette[eventLabel];
                    }

                    if (/https?:\/\/(www\.)?(t\.me|telegram\.me|instagram\.com|tiktok\.com|pinterest\.com|youtube\.com|youtu\.be|linktr\.ee|spotify\.com|disqus\.com|gravatar\.com|kaggle\.com|habbo\.com)/i.test(lowerLabel)) {
                        color = "#845ef7";
                    } else if (/https?:\/\/(www\.)?(github\.com|gitlab\.com|bitbucket\.org|play\.google\.com|apps\.apple\.com|microsoft\.com\/store)/i.test(lowerLabel)) {
                        color = "#20c997";
                    } else if (/https?:\/\/[^\s]+/.test(lowerLabel)) {
                        color = "#74c69d";
                    }

                    if (!color) {
                        if (lowerLabel.indexOf("(category: social)") >= 0) {
                            color = "#845ef7";
                        } else if (lowerLabel.indexOf("(category: video)") >= 0 || lowerLabel.indexOf("(category: music)") >= 0) {
                            color = "#e599f7";
                        } else if (lowerLabel.indexOf("(category: image)") >= 0 || lowerLabel.indexOf("(category: blog)") >= 0) {
                            color = "#f06595";
                        } else if (lowerLabel.indexOf("(category: coding)") >= 0) {
                            color = "#20c997";
                        } else if (lowerLabel.indexOf("(category: finance)") >= 0) {
                            color = "#94d82d";
                        } else if (lowerLabel.indexOf("(category: gaming)") >= 0) {
                            color = "#ff922b";
                        }
                    }

                    if (!color) {
                        if (/^[a-z0-9._-]{3,64}$/i.test(labelText) && !/@/.test(labelText) && !/https?:\/\//i.test(labelText)) {
                            color = "#fcc419";
                        } else if (/^[A-Za-zÀ-ÿ'`.-]+(?:\s+[A-Za-zÀ-ÿ'`.-]+)+$/.test(labelText) && !/https?:\/\//i.test(labelText)) {
                            color = "#ff922b";
                        }
                    }

                    return color || "#adb5bd";
                }
                s.graph.nodes().forEach(function(node) {
                    node.label = cleanGraphText(node.label);
                    node.sfFullLabel = cleanGraphText(node.sfFullLabel || node.label);
                    node.color = inferGraphNodeColor(node);
                    node.originalColor = node.color;
                    node.active_color = node.color;
                });
                s.settings({
                    edgeColor: 'default',
                    defaultEdgeColor: '#8b949e',
                    minNodeSize: 2,
                    maxNodeSize: 10,
                    defaultLabelSize: 11,
                    labelThreshold: 6,
                    defaultLabelColor: '#d4d4d4'
                });
                graphLabelModeUpdate(graphLabelMode, false);
                function linkifyGraphText(text) {
                    var cleaned = cleanGraphText(text);
                    var escaped = $("<div>").text(cleaned).html();
                    return escaped.replace(
                        /(https?:\/\/[^\s<]+)/g,
                        "<a href='$1' target='_blank' rel='noopener noreferrer'>$1</a>"
                    );
                }
                function renderNodeInfo(node) {
                    var details = "<div><b>" + linkifyGraphText(node.sfFullLabel || node.label || "Sem rótulo") + "</b></div>";
                    if (node.sfEventLabel) {
                        details += "<div style='margin-top:6px;'><b>Tipo:</b> " + linkifyGraphText(node.sfEventLabel) + "</div>";
                    }
                    if (node.sfOccurrences !== undefined) {
                        details += "<div><b>Ocorrências:</b> " + node.sfOccurrences + "</div>";
                    }
                    if (node.sfDegree !== undefined) {
                        details += "<div><b>Conexões:</b> " + node.sfDegree + "</div>";
                    }
                    if (node.sfModuleCount !== undefined) {
                        details += "<div><b>Módulos:</b> " + node.sfModuleCount + "</div>";
                    }
                    if (node.sfModules) {
                        details += "<div style='margin-top:6px;'><b>Fontes/Módulos:</b><br>" + linkifyGraphText(node.sfModules) + "</div>";
                    }
                    $("#graph-node-info").html(details);
                }
                s.bind('overNode', function(e) { renderNodeInfo(e.data.node); });
                s.bind('clickNode', function(e) { renderNodeInfo(e.data.node); });
                sigma.plugins.dragNodes(s, s.renderers[0])
                s.refresh()
                $("#loader").hide();
            });
        }

        function graphLabelModeUpdate(mode, refreshGraph) {
            if (typeof refreshGraph === "undefined") {
                refreshGraph = true;
            }

            graphLabelMode = mode;
            $("#btn-labels-relevant").toggleClass("active", mode == "relevant");
            $("#btn-labels-all").toggleClass("active", mode == "all");
            $("#btn-labels-off").toggleClass("active", mode == "off");

            if (!sharedSigma) {
                return;
            }

            if (mode == "all") {
                sharedSigma.settings({
                    drawLabels: true,
                    labelThreshold: 0,
                    defaultLabelSize: 11
                });
            }

            if (mode == "relevant") {
                sharedSigma.settings({
                    drawLabels: true,
                    labelThreshold: 6,
                    defaultLabelSize: 11
                });
            }

            if (mode == "off") {
                sharedSigma.settings({
                    drawLabels: false
                });
            }

            if (refreshGraph) {
                sharedSigma.refresh();
            }
        }

        function vizUpdate(method) {
            s = sharedSigma
            if (method == "force") {
                $("#btn-forceatlas").addClass("active");
                $("#btn-random").removeClass("active");
                s.startForceAtlas2();
                s.refresh();
                setTimeout(function() { s.stopForceAtlas2() }, 5000);
            }

            if (method == "random") {
                $("#btn-forceatlas").removeClass("active");
                $("#btn-random").addClass("active");
                refresh();
            }

            if (method == "download") {
                s.renderers[0].snapshot({download: true});
            }
        }

