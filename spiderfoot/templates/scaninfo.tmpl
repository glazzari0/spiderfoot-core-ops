                            table += "<tr id='finding-inline-row' style='display:none;'><td colspan='6'>" + workbench + "</td></tr>";
                            table += "</tbody></table>"
                            $("#loader").fadeOut(500);
                            $("#mainbody").append(crumbs + "<div id='scansummary-content'>" + generalOpsPanel + table + "</div>");
                            refreshOperationalSummary(instanceId);
                            $("#finding-list-table").tablesorter({ headers: { 0: { sorter: false }, 5: { sorter: false } } });
                            lastChecked = null;
