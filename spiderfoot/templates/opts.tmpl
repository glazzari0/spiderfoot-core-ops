<%include file="HEADER.tmpl"/>
    <script type='text/javascript' src='${docroot}/static/js/spiderfoot.opts.js'></script>
<div class="sf-page-shell">
    <div class="sf-page-header">
      <div>
        <h2 class="sf-page-title">Configurações</h2>
        <div class="sf-page-subtitle">Ajuste preferências globais, APIs e opções de cada módulo em uma visão mais limpa e organizada.</div>
      </div>
    </div>
% if updated:
<div class="alert alert-success">
 <button type="button" class="close" data-dismiss="alert">&times;</button>
 <h4>Sucesso!</h4>
 As configurações foram atualizadas. Elas entrarão em vigor na próxima varredura.
</div>
% endif
<form class="form" action='${docroot}/savesettings' id="savesettingsform" method='POST' enctype="multipart/form-data">
<div class='text-left'>
    <input type=hidden id='allopts' name='allopts' value=''>
    <input type=hidden id='token' name='token' value="${token}">
    <input type="file" name='configFile' id="configFile" class='hidden' onChange='$("#savesettingsform").submit()' />
    <button id="btn-save-changes" class='btn btn-primary' type="submit">Salvar Alterações</button>
    <button id="btn-import-config" class='btn btn-info'>Importar Chaves de API</button>
    <button id="btn-opt-export" class='btn btn-info'>Exportar Chaves de API</button>
    <button id="btn-reset-settings" class='btn btn-danger'>Restaurar Padrão de Fábrica</button>
<br><br>
</div>
% if selected_module:
<script type='text/javascript'>
window.preselectedModule = "${selected_module}";
</script>
% endif

<div class="tabbable tabs-left">
<div class="col-md-3" style="padding-left: 0;">
<div class="sf-table-shell" style="padding: 12px;">
<ul class="nav nav-pills nav-stacked">
<li id='tab_global' class="active"><a href="#">Geral</a></li>
<li id='tab_ai'><a href='#' onclick='switchTab("ai");'>IA / Ollama</a></li>
% for mod in sorted(opts['__modules__'].keys()):
    <% keylist = dict((k, v) for k, v in opts['__modules__'][mod]['opts'].items() if not k.startswith('_')) %>
    % if len(keylist) > 0:
        <% keyicon = "" %>
        <% apikeylist = dict((k, v) for k, v in opts['__modules__'][mod]['opts'].items() if k.find("api_key") >= 0) %>
        <% 
        if len(apikeylist) > 0: 
            keyicon = "&nbsp;&nbsp;<i class=\"glyphicon glyphicon-lock\"></i>"
        %>
        <li id='tab_${mod}'><a href='#' onclick='switchTab("${mod}");' >${opts['__modules__'][mod]['name']}${keyicon}</a></li>
    % endif
% endfor
</ul>
</div>
</div>
</div>

<div class="tab-content col-md-9">

<div id='optsect_global' class="tab-pane active">
<h4>Configurações Gerais</h4>
<div class="sf-table-shell">
<table class='table table-striped'>
<thead><tr> <th>Opção</th> <th>Valor</th></tr></thead><tbody>
% for opt in sorted(opts.keys()):
    % if not opt.startswith("__") and not opt.startswith("_ai_"):
    <tr><td>${opts['__globaloptdescs__'].get(opt) or "Sem descrição disponível"}</td><td style='vertical-align: middle'>
        % if type(opts[opt]) is int:
        <div class='form-group'>
            <input id='${opt}' class='form-control' type=text value="${opts[opt]}">
        </div>
        % endif
        % if type(opts[opt]) is str:
        <div class='form-group'>
            % if opt in ["_ai_ollama_chat_model", "_ai_ollama_embedding_model"]:
            <input id='${opt}' list='ai-ollama-models' style='width: 500px' class='form-control' type=text value="${opts[opt]}">
            % else:
            <input id='${opt}' style='width: 500px' class='form-control' type=text value="${opts[opt]}">
            % endif
        </div>
        % endif
        % if type(opts[opt]) is bool:
        <%
            if opts[opt] == True:
                seltrue = "selected"
                selfalse = ""
            else:
                selfalse = "selected"  
                seltrue = ""
        %>
            <select id='${opt}' class='form-control'>
                <option value=1 ${seltrue}>Verdadeiro</option>
                <option value=0 ${selfalse}>Falso</option>
            </select>
        % endif
        % if type(opts[opt]) is list and type(opts[opt][0]) is str:
            <% expandedopt = ','.join(opts[opt]) %>
            <div class='form-group'>
                <input id='${opt}' style='width: 500px' class='form-control' type=text value="${expandedopt}">
            </div>
        % endif
        % if type(opts[opt]) is list and type(opts[opt][0]) is int:
            <% expandedopt = ','.join(str(x) for x in opts[opt]) %>
            <div class='form-group'>
                <input id='${opt}' class='form-control' type=text value="${expandedopt}">
            </div>
        % endif
    </td></tr>
    % endif
% endfor
</tbody>
</table>
</div>
</div>

<div id='optsect_ai' class="tab-pane" style="display: none">
<h4>IA / Ollama</h4>
<div class="alert alert-info">
 A camada de IA do SpiderFoot Core-Ops foi planejada para funcionar localmente. Use o Ollama como backend de LLM e embeddings
 e mantenha os demais modelos como motores pr&oacute;prios da plataforma, como classificadores, rankeadores, detectores de mudan&ccedil;a
 e aprendizado por feedback do analista.
</div>
<div class="sf-table-shell" style="margin-bottom: 18px;">
<table class='table table-striped'>
<tbody>
<tr><td style="width: 220px;">LLM local</td><td>O Ollama pode ser usado para sumariza&ccedil;&atilde;o, correla&ccedil;&atilde;o assistida, sugest&atilde;o de piv&ocirc;s e vereditos assistidos.</td></tr>
<tr><td>Modelos pr&oacute;prios</td><td>Os demais componentes podem evoluir como &aacute;rvores de decis&atilde;o, redes neurais, motores de ranking e detectores espec&iacute;ficos para cada tipo de caso.</td></tr>
<tr><td>Aprendizado local</td><td>Classifica&ccedil;&otilde;es, valida&ccedil;&otilde;es e vereditos do analista podem alimentar o aperfei&ccedil;oamento dos modelos locais sem depender de servidores externos.</td></tr>
</tbody>
</table>
</div>
<div class="sf-table-shell">
<table class='table table-striped'>
<thead><tr> <th>Op&ccedil;&atilde;o</th> <th>Valor</th></tr></thead><tbody>
% for opt in sorted(opts.keys()):
    % if opt.startswith("_ai_"):
    <tr><td>${opts['__globaloptdescs__'].get(opt) or "Sem descri&ccedil;&atilde;o dispon&iacute;vel"}</td><td style='vertical-align: middle'>
        % if type(opts[opt]) is int:
        <div class='form-group'>
            <input id='${opt}' class='form-control' type=text value="${opts[opt]}">
        </div>
        % endif
        % if type(opts[opt]) is str:
        <div class='form-group'>
            <input id='${opt}' style='width: 500px' class='form-control' type=text value="${opts[opt]}">
        </div>
        % endif
        % if type(opts[opt]) is bool:
        <%
            if opts[opt] == True:
                seltrue = "selected"
                selfalse = ""
            else:
                selfalse = "selected"
                seltrue = ""
        %>
            <select id='${opt}' class='form-control'>
                <option value=1 ${seltrue}>Verdadeiro</option>
                <option value=0 ${selfalse}>Falso</option>
            </select>
        % endif
        % if type(opts[opt]) is list and type(opts[opt][0]) is str:
            <% expandedopt = ','.join(opts[opt]) %>
            <div class='form-group'>
                <input id='${opt}' style='width: 500px' class='form-control' type=text value="${expandedopt}">
            </div>
        % endif
        % if type(opts[opt]) is list and type(opts[opt][0]) is int:
            <% expandedopt = ','.join(str(x) for x in opts[opt]) %>
            <div class='form-group'>
                <input id='${opt}' class='form-control' type=text value="${expandedopt}">
            </div>
        % endif
    </td></tr>
    % endif
% endfor
</tbody>
</table>
</div>
<div style="margin-top: 14px;">
    <button id="btn-ai-test-ollama" class="btn btn-info">Validar conexão e listar modelos</button>
    <span id="ai-ollama-status" class="text-muted" style="margin-left: 12px;">Use este teste para confirmar conectividade com o Ollama antes de rodar a análise assistida.</span>
</div>
<div id="ai-ollama-model-summary" class="font-size-90-percent text-muted" style="margin-top: 10px;"></div>
<datalist id="ai-ollama-models"></datalist>
</div>
% for mod in sorted(opts['__modules__'].keys()):
    <%
        summary = opts['__modules__'][mod].get('descr') or 'No summary available.'
        categories = opts['__modules__'][mod].get('cats') or []
        labels = opts['__modules__'][mod].get('labels') or []
        meta = opts['__modules__'][mod].get('meta')
        modopts = opts['__modules__'][mod].get('opts')
        optdescs = opts['__modules__'][mod].get('optdescs')
        data_source = meta.get('dataSource') or {}
        website = data_source.get('website') or ''
        description = data_source.get('description') or ''
        apiKeyInstructions = data_source.get('apiKeyInstructions') or ''
    %>
    <div id='optsect_${mod}' class="tab-pane" style="display: none">
    <h4>${opts['__modules__'][mod]['name']} (${mod})</h4>

    <div class="sf-table-shell">
    <table class='table table-striped'>
    <tbody>
    <tr><td>Resumo</td><td>${summary}<br/><br/>${description}</td></tr>

    % if categories:
    <tr><td>Categorias:</td><td>${', '.join(categories)}</td><tr>
    % endif

    % if labels:
    <tr><td>Tags:</td><td>${', '.join(labels)}</td><tr>
    % endif

    % if website:
    <tr><td>Site:</td><td><a href="${website}" target=_new>${website}</a></td></tr>
    % endif

    </tbody>
    </table>
    </div>

    <h4>Configurações</h4>
    <div class="sf-table-shell">
    <table class='table table-striped'>
    <thead><tr><th>Opção</th> <th>Valor</th></tr></thead>
    <tbody>

    % for opt in sorted(modopts.keys()):
        % if not opt.startswith("_"):
            <tr>
              <td>${optdescs.get(opt) or "No description available."}
                % if "api_key" in opt:
                    % if apiKeyInstructions:
                        <%
                            import re
                            instructions = ""
                            for step in apiKeyInstructions:
                                if "https://" in step or "http://" in step:
                                    step = re.sub(r'(https?://.[^ ]+)', '<a target=_new href=\'\\1\'>\\1</a>', step)
                                instructions += f"<li>{step}</li>"
                        %>
                        &nbsp;&nbsp;<a href='#' data-html="true" data-toggle="popover" data-trigger="focus" title="Instructions" data-content="<ol>${instructions}</ol>"><i class="glyphicon glyphicon-question-sign"></i></a>
                    % endif
                % endif
              </td>
              <td style='vertical-align: middle'>
            % if type(modopts[opt]) is int:
                <div class='form-group'>
                    <input id='${mod}:${opt}' class='form-control' type=text value="${modopts[opt]}">
                </div>
            % endif
            % if type(modopts[opt]) is str:
                <div class='form-group'>
                    <input id='${mod}:${opt}' style='width: 500px' class='form-control' type=text value="${modopts[opt]}">
                </div>
            % endif
            % if type(modopts[opt]) is bool:
            <%
                if modopts[opt] == True:
                    seltrue = "selected"
                    selfalse = ""
                else:
                    selfalse = "selected"
                    seltrue = ""
            %>
                <select id='${mod}:${opt}' class='form-control'>
                    <option value=1 ${seltrue}>True</option>
                    <option value=0 ${selfalse}>False</option>
                </select>
            % endif
            % if type(modopts[opt]) is list and type(modopts[opt][0]) is str:
                <% expandedopt = ','.join(modopts[opt]) %>
                <div class='form-group'>
                    <input id='${mod}:${opt}' style='width: 500px' class='form-control' type=text value="${expandedopt}">
                </div>
            % endif
            % if type(modopts[opt]) is list and type(modopts[opt][0]) is int:
                <% expandedopt = ','.join(str(x) for x in modopts[opt]) %>
                <div class='form-group'>
                    <input id='${mod}:${opt}' class='form-control' type=text value="${expandedopt}">
                </div>
            % endif

            </td></tr>
        % endif
    % endfor
    </tbody>
    </table>
    </div>
    </div>
% endfor
</div>
</div> <!-- /tabbable tabs-left -->
</form>
<br><br>
</div>
<%include file="FOOTER.tmpl"/>
